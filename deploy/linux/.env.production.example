NODE_ENV=production
APP_DOMAIN=example.com
LETSENCRYPT_EMAIL=ops@example.com

PORT=3001
WEB_PORT=3000
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/music_room
REDIS_URL=redis://redis:6379
REDIS_MODE=single
REDIS_SENTINELS=
REDIS_SENTINEL_MASTER_NAME=
REDIS_SENTINEL_USERNAME=
REDIS_SENTINEL_PASSWORD=
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
JWT_SECRET=replace-this-with-a-long-random-secret
CORS_ORIGINS=https://example.com
AUTH_FAKE_PERSISTENCE=false
AUTH_FAKE_PERSIST_PATH=.tmp/auth-fallback-store.json

NEXT_PUBLIC_API_BASE_URL=https://example.com
NEXT_PUBLIC_WS_URL=wss://example.com
NEXT_PUBLIC_SOCKET_PATH=/ws/socket.io
NEXT_PUBLIC_STUN_URL=stun:stun.l.google.com:19302
NEXT_PUBLIC_TURN_URL=turn:turn.example.com:3478?transport=udp
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=
NEXT_PUBLIC_WEBRTC_ICE_SERVERS=
TURN_ENABLED=true
TURN_PUBLIC_HOST=turn.example.com
TURN_REALM=turn.example.com
TURN_PORT=3478
TURN_TLS_PORT=5349
TURN_MIN_PORT=49160
TURN_MAX_PORT=49200
TURN_SHARED_SECRET=replace-with-a-turn-shared-secret
SERVER_IMAGE=ghcr.io/your-org/music-room-server:latest
WEB_IMAGE=ghcr.io/your-org/music-room-web:latest
TURN_PROTOCOLS=udp,tcp,tls
TURN_TTL_SECONDS=3600
TURN_EXTERNAL_IP=your-public-ip

POSTGRES_DB=music_room
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
