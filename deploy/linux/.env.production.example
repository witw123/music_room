NODE_ENV=production
APP_DOMAIN=music.example.com
LETSENCRYPT_EMAIL=ops@example.com

PORT=3001
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/music_room
REDIS_URL=redis://redis:6379
JWT_SECRET=replace-this-with-a-long-random-secret
CORS_ORIGINS=https://music.example.com
AUTH_FAKE_PERSISTENCE=false

NEXT_PUBLIC_API_BASE_URL=https://music.example.com
NEXT_PUBLIC_WS_URL=wss://music.example.com
NEXT_PUBLIC_SOCKET_PATH=/ws/socket.io
NEXT_PUBLIC_STUN_URL=stun:stun.l.google.com:19302
NEXT_PUBLIC_TURN_URL=turn:turn.music.example.com:3478
NEXT_PUBLIC_TURN_USERNAME=music-room
NEXT_PUBLIC_TURN_CREDENTIAL=replace-with-turn-password
NEXT_PUBLIC_WEBRTC_ICE_SERVERS=

POSTGRES_DB=music_room
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
