{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Music Room",
  "version": "0.8.1",
  "identifier": "top.witw.musicroom",
  "build": {
    "frontendDist": "../bootstrap",
    "devUrl": "http://localhost:3000/app?client=desktop"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Music Room",
        "width": 1440,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; media-src 'self' blob:; connect-src 'self' http://127.0.0.1:37421 https://musicroom.witw.top wss://musicroom.witw.top; frame-ancestors 'none'; object-src 'none'; base-uri 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "../dist/web/app/": "web/",
      "../dist/node/": "node/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/witw123/music_room/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  }
}
