{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Allow the main Music Room desktop window to use the default Tauri APIs.",
  "windows": [
    "main"
  ],
  "remote": {
    "urls": [
      "http://localhost:3000",
      "http://localhost:3000/*",
      "https://example.com",
      "https://example.com/*"
    ]
  },
  "permissions": [
    "core:default",
    "default",
    "process:default",
    "updater:default"
  ]
}
