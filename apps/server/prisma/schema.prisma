generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum IncidentSeverity {
  DEGRADED
  CRITICAL
}

enum IncidentStatus {
  OPEN
  RECOVERED
}

model User {
  id             String          @id
  username       String          @unique
  passwordHash   String
  nickname       String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  role           UserRole        @default(USER)
  status         UserStatus      @default(ACTIVE)
  disabledAt     DateTime?
  disabledReason String?
  lastLoginAt    DateTime?
  neteaseAccount NeteaseAccount?
  qqMusicAccount QqMusicAccount?
  adminSessions  AdminSession[]
  userSessions   UserSession[]
  auditLogs      AdminAuditLog[]
}

model AdminSession {
  id           String    @id
  userId       String
  tokenHash    String    @unique
  csrfHash     String
  createdAt    DateTime  @default(now())
  lastActiveAt DateTime  @default(now())
  expiresAt    DateTime
  revokedAt    DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model NeteaseAccount {
  id              String    @id
  userId          String    @unique
  neteaseUserId   String?
  nickname        String?
  avatarUrl       String?
  encryptedCookie String
  lastValidatedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model QqMusicAccount {
  id              String    @id
  userId          String    @unique
  qqMusicUserId   String?
  nickname        String?
  avatarUrl       String?
  encryptedCookie String
  lastValidatedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSession {
  id        String   @id
  userId    String
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model RoomState {
  id               String   @id
  hostId           String
  joinCode         String   @unique
  name             String   @default("未命名房间")
  description      String?
  passwordHash     String?
  visibility       String
  roomRevision     Int      @default(0)
  presenceRevision Int      @default(0)
  playback         Json
  members          Json
  tracks           Json
  queue            Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Playlist {
  id              String   @id
  ownerId         String
  roomId          String?
  title           String
  description     String?
  coverUrl        String?
  tags            Json
  isCollaborative Boolean  @default(false)
  trackIds        Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([ownerId, updatedAt])
  @@index([roomId])
}

model OperationalIncident {
  id              String           @id
  fingerprint     String           @unique
  type            String
  scopeType       String
  scopeId         String?
  severity        IncidentSeverity
  status          IncidentStatus   @default(OPEN)
  firstSeenAt     DateTime
  lastSeenAt      DateTime
  recoveredAt     DateTime?
  occurrenceCount Int              @default(1)
  details         Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([status, severity, lastSeenAt])
  @@index([scopeType, scopeId])
}

model AdminAuditLog {
  id          String   @id
  actorUserId String
  action      String
  targetType  String
  targetId    String?
  reason      String?
  result      String
  requestId   String?
  ipHash      String?
  userAgent   String?
  createdAt   DateTime @default(now())
  actor       User     @relation(fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([actorUserId, createdAt])
  @@index([targetType, targetId])
}

model RoomTombstone {
  id        String   @id
  roomId    String   @unique
  trackIds  Json
  reason    String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([status, createdAt])
  @@index([expiresAt])
}
