generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id
  username     String   @unique
  passwordHash String
  nickname     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  sessions     UserSession[]
  playlists    Playlist[]
}

model UserSession {
  id        String   @id
  userId    String
  tokenHash String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model RoomState {
  id               String   @id
  hostId           String
  joinCode         String   @unique
  visibility       String
  roomRevision     Int      @default(0)
  presenceRevision Int      @default(0)
  playback         Json
  members          Json
  tracks           Json
  queue            Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  lastActiveAt     DateTime @default(now())
  archivedAt       DateTime?
}

model Playlist {
  id              String   @id
  ownerId         String
  roomId          String?
  title           String
  description     String?
  coverUrl        String?
  tags            Json
  isCollaborative Boolean  @default(false)
  trackIds        Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  owner           User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([roomId])
}
