generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model GuestSession {
  id        String   @id
  nickname  String
  token     String
  createdAt DateTime @default(now())
}

model Playlist {
  id          String   @id
  ownerId     String
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
