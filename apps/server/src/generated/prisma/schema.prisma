generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model GuestSession {
  id        String   @id
  nickname  String
  token     String
  createdAt DateTime @default(now())
}

model RoomState {
  id         String   @id
  hostId     String
  joinCode   String   @unique
  visibility String
  playback   Json
  members    Json
  tracks     Json
  queue      Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Playlist {
  id              String   @id
  ownerId         String
  roomId          String?
  title           String
  description     String?
  coverUrl        String?
  tags            Json
  isCollaborative Boolean  @default(false)
  trackIds        Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
