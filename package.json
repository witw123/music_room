{
  "name": "music-room",
  "version": "0.2.8",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "e2e": "pnpm --filter @music-room/web e2e",
    "check:toolchain": "node scripts/check-toolchain.mjs",
    "deploy:check": "node scripts/deploy-check.mjs",
    "deploy:linux": "sh scripts/deploy-linux.sh",
    "migrate:p2p-v4": "pnpm --filter @music-room/server migrate:p2p-v4"
  },
  "pnpm": {
    "overrides": {
      "defu": "6.1.7",
      "effect": "3.22.0",
      "lodash": "4.18.1",
      "multer": "2.2.0",
      "path-to-regexp": "8.4.2",
      "postcss": "8.5.19",
      "qs": "6.15.3",
      "sharp": "0.35.3",
      "engine.io": "6.6.7",
      "ws": "8.21.1"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@next/eslint-plugin-next": "^15.2.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^14.0.0",
    "turbo": "^2.5.0",
    "typescript-eslint": "^8.26.1",
    "typescript": "^5.8.2"
  }
}
