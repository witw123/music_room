{
  "name": "music-room",
  "version": "0.2.4",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:desktop": "turbo run dev --filter=@music-room/server --filter=@music-room/web --filter=@music-room/desktop --parallel",
    "build": "turbo run build",
    "build:desktop": "turbo run build --filter=@music-room/desktop",
    "build:mobile": "turbo run build --filter=@music-room/mobile",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "pack:desktop": "turbo run pack --filter=@music-room/desktop",
    "pack:mobile": "turbo run pack --filter=@music-room/mobile",
    "deploy:check": "node scripts/deploy-check.mjs",
    "deploy:linux": "sh scripts/deploy-linux.sh"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp"
    ]
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.2"
  }
}
