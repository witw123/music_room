NODE_ENV=development
PORT=3001
WEB_PORT=3000
APP_DOMAIN=localhost
LETSENCRYPT_EMAIL=ops@example.com
POSTGRES_DB=music_room
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-local-postgres-password
DATABASE_URL=postgresql://postgres:replace-with-a-local-postgres-password@localhost:5432/music_room
REDIS_URL=redis://localhost:6379
REDIS_MODE=single
REDIS_SENTINELS=
REDIS_SENTINEL_MASTER_NAME=
REDIS_SENTINEL_USERNAME=
REDIS_SENTINEL_PASSWORD=
REDIS_USERNAME=
REDIS_PASSWORD=replace-with-a-local-redis-password
REDIS_DB=0
JWT_SECRET=replace-this-with-a-long-random-secret
AUDIT_HASH_SECRET=replace-this-with-a-separate-audit-hmac-secret
METRICS_TOKEN=replace-with-internal-prometheus-token
ADMIN_PANEL_ENABLED=true
ADMIN_MUTATIONS_ENABLED=false
CLIENT_TELEMETRY_ENABLED=true
NEXT_PUBLIC_CLIENT_TELEMETRY_ENABLED=true
ALERT_WEBHOOK_URL=https://example.invalid/alerts
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
AUTH_FAKE_PERSISTENCE=true
AUTH_FAKE_PERSIST_PATH=.tmp/auth-fallback-store.json
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_SOCKET_PATH=/ws/socket.io
NEXT_PUBLIC_STUN_URL=stun:stun.l.google.com:19302
NEXT_PUBLIC_TURN_URL=turn:localhost:3478?transport=udp
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=
NEXT_PUBLIC_WEBRTC_ICE_SERVERS=
TURN_REALM=localhost
TURN_ENABLED=true
TURN_PUBLIC_HOST=localhost
# Set TURN_PUBLIC_HOST_USE_APP_DOMAIN=1 to reuse APP_DOMAIN as the TURN host
# (skips the automatic "turn." prefix). Useful when TURN shares the same domain.
TURN_PUBLIC_HOST_USE_APP_DOMAIN=0
TURN_PUBLIC_HOST_USE_REQUEST_HOST=0
TURN_REQUEST_HOST_ALLOWLIST=
TURN_PORT=3478
TURN_MIN_PORT=49160
TURN_MAX_PORT=49200
TURN_SHARED_SECRET=replace-with-a-turn-shared-secret
TURN_PROTOCOLS=udp
TURN_TTL_SECONDS=3600
TURN_EXTERNAL_IP=your-public-ip
NETEASE_ENABLED=false
NETEASE_COOKIE_ENCRYPTION_KEY=
NETEASE_DEFAULT_QUALITY=exhigh
NETEASE_MAX_IMPORT_BYTES=209715200
NETEASE_REQUEST_TIMEOUT_MS=15000
QQMUSIC_ENABLED=false
QQMUSIC_COOKIE_ENCRYPTION_KEY=
QQMUSIC_DEFAULT_QUALITY=exhigh
QQMUSIC_MAX_IMPORT_BYTES=209715200
QQMUSIC_REQUEST_TIMEOUT_MS=15000
KUGOU_ENABLED=false
KUWO_ENABLED=false
TAIHE_ENABLED=true
MIGU_ENABLED=true
BAIDU_ENABLED=false
METING_DEFAULT_QUALITY=exhigh
METING_MAX_IMPORT_BYTES=209715200
METING_REQUEST_TIMEOUT_MS=15000
METING_URL_RETRY_COUNT=1
NEXT_PUBLIC_NETEASE_ENABLED=false
NEXT_PUBLIC_QQMUSIC_ENABLED=false
NEXT_PUBLIC_KUGOU_ENABLED=false
NEXT_PUBLIC_KUWO_ENABLED=false
NEXT_PUBLIC_TAIHE_ENABLED=true
NEXT_PUBLIC_MIGU_ENABLED=true
NEXT_PUBLIC_BAIDU_ENABLED=false
GHCR_OWNER=your-org
RELEASE_TAG=sha-replace-with-full-commit-sha
