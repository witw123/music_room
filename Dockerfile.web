FROM node:22-alpine AS base
WORKDIR /app
RUN npm install -g pnpm@10.0.0

FROM base AS deps
COPY package.json pnpm-workspace.yaml turbo.json pnpm-lock.yaml ./
COPY apps/web/package.json apps/web/package.json
COPY packages/shared/package.json packages/shared/package.json
COPY packages/opus-encode/package.json packages/opus-encode/package.json
COPY packages/config-eslint/package.json packages/config-eslint/package.json
COPY packages/config-typescript/package.json packages/config-typescript/package.json
RUN pnpm install --filter @music-room/web... --frozen-lockfile=true

FROM base AS builder
ARG NEXT_PUBLIC_API_BASE_URL=
ARG NEXT_PUBLIC_WS_URL=
ARG NEXT_PUBLIC_SOCKET_PATH=/ws/socket.io
ARG NEXT_PUBLIC_STUN_URL=stun:stun.l.google.com:19302
ARG NEXT_PUBLIC_TURN_URL=
ARG NEXT_PUBLIC_TURN_USERNAME=
ARG NEXT_PUBLIC_TURN_CREDENTIAL=
ARG NEXT_PUBLIC_WEBRTC_ICE_SERVERS=
ARG NEXT_PUBLIC_NETEASE_ENABLED=false
ARG NEXT_PUBLIC_QQMUSIC_ENABLED=false
ARG NEXT_PUBLIC_KUGOU_ENABLED=false
ARG NEXT_PUBLIC_KUWO_ENABLED=false
ARG NEXT_PUBLIC_TAIHE_ENABLED=false
ARG NEXT_PUBLIC_MIGU_ENABLED=false
ARG NEXT_PUBLIC_BAIDU_ENABLED=false
ENV NEXT_PUBLIC_API_BASE_URL=${NEXT_PUBLIC_API_BASE_URL}
ENV NEXT_PUBLIC_WS_URL=${NEXT_PUBLIC_WS_URL}
ENV NEXT_PUBLIC_SOCKET_PATH=${NEXT_PUBLIC_SOCKET_PATH}
ENV NEXT_PUBLIC_STUN_URL=${NEXT_PUBLIC_STUN_URL}
ENV NEXT_PUBLIC_TURN_URL=${NEXT_PUBLIC_TURN_URL}
ENV NEXT_PUBLIC_TURN_USERNAME=${NEXT_PUBLIC_TURN_USERNAME}
ENV NEXT_PUBLIC_TURN_CREDENTIAL=${NEXT_PUBLIC_TURN_CREDENTIAL}
ENV NEXT_PUBLIC_WEBRTC_ICE_SERVERS=${NEXT_PUBLIC_WEBRTC_ICE_SERVERS}
ENV NEXT_PUBLIC_NETEASE_ENABLED=${NEXT_PUBLIC_NETEASE_ENABLED}
ENV NEXT_PUBLIC_QQMUSIC_ENABLED=${NEXT_PUBLIC_QQMUSIC_ENABLED}
ENV NEXT_PUBLIC_KUGOU_ENABLED=${NEXT_PUBLIC_KUGOU_ENABLED}
ENV NEXT_PUBLIC_KUWO_ENABLED=${NEXT_PUBLIC_KUWO_ENABLED}
ENV NEXT_PUBLIC_TAIHE_ENABLED=${NEXT_PUBLIC_TAIHE_ENABLED}
ENV NEXT_PUBLIC_MIGU_ENABLED=${NEXT_PUBLIC_MIGU_ENABLED}
ENV NEXT_PUBLIC_BAIDU_ENABLED=${NEXT_PUBLIC_BAIDU_ENABLED}
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/web/node_modules ./apps/web/node_modules
COPY --from=deps /app/packages/shared/node_modules ./packages/shared/node_modules
COPY --from=deps /app/packages/opus-encode/node_modules ./packages/opus-encode/node_modules
COPY . .
RUN pnpm --filter @music-room/shared build
RUN pnpm --filter @music-room/web build

FROM node:22-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static
EXPOSE 3000
CMD ["node", "apps/web/server.js"]
